<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F4F8">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1B3A6B"
        android:padding="20dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/btnBack"
            android:text="← "
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="New Sale"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- STEP 1: SELECT ITEM -->
            <TextView
                android:text="Step 1: What did you sell?"
                android:textColor="#1B3A6B"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <GridLayout
                android:id="@+id/gridItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="3"
                android:layout_marginBottom="20dp"/>

            <!-- STEP 2: SELECT COLOR -->
            <TextView
                android:text="Step 2: Which color/design?"
                android:textColor="#1B3A6B"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <GridLayout
                android:id="@+id/gridColors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="3"
                android:layout_marginBottom="20dp"/>

            <!-- PRICE INPUT -->
            <TextView
                android:text="Price per item (₹)"
                android:textColor="#1B3A6B"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/etPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter price e.g. 150"
                android:inputType="numberDecimal"
                android:background="@drawable/edit_text_bg"
                android:padding="14dp"
                android:textSize="16sp"
                android:layout_marginBottom="24dp"/>

            <!-- SAVE BUTTON -->
            <Button
                android:id="@+id/btnSaveSale"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="✅  Save Sale"
                android:textSize="18sp"
                android:textStyle="bold"
                android:backgroundTint="#0E7C7B"
                android:textColor="#FFFFFF"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>